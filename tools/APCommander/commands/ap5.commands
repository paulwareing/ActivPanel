    <command name="Remote Management Off" bytes="F6 38 01 00 2F 6F"/>
    <command name="Standby Time?" bytes="F6 39 02 00 31 6F" response="enum">
        <enum value="00" result="2 min"/>
        <enum value="01" result="5 min"/>
        <enum value="02" result="10 min"/>
        <enum value="03" result="20 min"/>
        <enum value="04" result="30 min"/>
    </command>
    <command name="Standby Time..." bytes="F6 39 01 00 30 6F" input="enum">
        <enum value="00" result="2 min"/>
        <enum value="01" result="5 min"/>
        <enum value="02" result="10 min"/>
        <enum value="03" result="20 min"/>
        <enum value="04" result="30 min"/>
    </command>
    <command name="Shutdown Time?" bytes="F6 3A 02 00 32 6F" response="enum">
        <enum value="00" result="30 min"/>
        <enum value="01" result="45 min"/>
        <enum value="02" result="60 min"/>
        <enum value="03" result="90 min"/>
        <enum value="04" result="120 min"/>
    </command>
    <command name="Shutdown Time..." bytes="F6 3A 01 00 31 6F" input="enum">
        <enum value="00" result="30 min"/>
        <enum value="01" result="45 min"/>
        <enum value="02" result="60 min"/>
        <enum value="03" result="90 min"/>
        <enum value="04" result="120 min"/>
    </command>
    <command name="Picture Mode?" bytes="F6 34 01 00 2B 6F" response="enum">
        <enum value="00" result="Lightness"/>
        <enum value="01" result="Standard"/>
        <enum value="02" result="Soft"/>
        <enum value="03" result="User"/>
