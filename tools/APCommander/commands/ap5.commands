<apcommands panel="ap5">
    <port baudRate="38400" parity="None" dataBits="8" stopBits="1"/>
    <command name="Power Status?" bytes="F6 01 02 00 F9 6F" response="enum">
        <enum value="01" result="On"/>
        <enum value="02" result="Off"/>
        <enum value="03" result="Display Off (Remote Management On)"/>
        <enum value="04" result="Display On (Remote Management On)"/>
    </command>
    <command name="Power On" bytes="F6 01 01 01 F9 6F"/>
    <command name="Power Off" bytes="F6 01 01 00 F8 6F"/>
    <command name="Auto Power Off?" bytes="F6 01 03 00 FA 6F" response="enum">
        <enum value="00" result="Off"/>
        <enum value="01" result="On"/>
    </command>
    <command name="Auto Power Off" bytes="F6 01 04 00 FB 6F" input="value" min="0" max="1"/>
    <command name="Complete Shutdown" bytes="F6 01 05 00 FC 6F"/>
    <command name="Scaler FW Version?" bytes="F6 03 01 00 FA 6F" response="string"/>
    <command name="Touch FW Version?" bytes="F6 03 02 00 FB 6F" response="string"/>
    <command name="Touch SN?" bytes="F6 03 03 00 FC 6F" response="string"/>
    <command name="Panel SN?" bytes="F6 03 04 00 FD 6F" response="string"/>
    <command name="Panel Model Number?" bytes="F6 03 05 00 FE 6F" response="string"/>
    <command name="Factory Reset" bytes="F6 03 06 00 FF 6F"/>
    <command name="Volume?" bytes="F6 0C 02 00 04 6F" response="value"/>
    <command name="Volume Up" bytes="F6 0C 00 01 03 6F"/>
    <command name="Volume Down" bytes="F6 0C 00 00 02 6F"/>
    <command name="Set Volume..." bytes="F6 0C 01 00 03 6F" input="value" min="0" max="100"/>
    <command name="Mute?" bytes="F6 02 02 00 FA 6F" response="enum">
        <enum value="00" result="Off"/>
        <enum value="01" result="On"/>
    </command>
    <command name="Mute On" bytes="F6 02 00 01 F9 6F"/>
    <command name="Mute Off" bytes="F6 02 00 00 F8 6F"/>
    <command name="Source?" bytes="F6 30 02 00 28 6F" response="enum">
        <enum value="01" result="AV"/>
        <enum value="06" result="YPbPr"/>
        <enum value="08" result="VGA"/>
        <enum value="09" result="HDMI1"/>
        <enum value="0A" result="HDMI2"/>
        <enum value="13" result="HDMI3"/>
        <enum value="14" result="HDMI4"/>
        <enum value="12" result="OPS"/>
        <enum value="0B" result="MultiMedia"/>
    </command>
    <command name="Set AV" bytes="F6 30 01 01 28 6F"/>
    <command name="Set YPbPr" bytes="F6 30 01 06 2D 6F"/>
    <command name="Set VGA" bytes="F6 30 01 08 2F 6F"/>
    <command name="Set HDMI1" bytes="F6 30 01 09 30 6F"/>
    <command name="Set HDMI2" bytes="F6 30 01 0A 31 6F"/>
    <command name="Set HDMI3" bytes="F6 30 01 13 3A 6F"/>
    <command name="Set HDMI4" bytes="F6 30 01 14 3B 6F"/>
    <command name="Set OPS" bytes="F6 30 01 12 39 6F"/>
    <command name="Set MultiMedia" bytes="F6 30 01 0B 32 6F"/>
    <command name="OPS Installed?" bytes="F6 31 02 00 29 6F" response="enum">
        <enum value="00" result="No"/>
        <enum value="01" result="Yes"/>
    </command>
    <command name="OPS On/Off?" bytes="F6 31 03 00 2A 6F" response="enum">
        <enum value="00" result="Off"/>
        <enum value="01" result="On"/>
    </command>
    <command name="OPS On" bytes="F6 31 01 01 29 6F"/>
    <command name="OPS Off" bytes="F6 31 01 02 2A 6F"/>
    <command name="Freeze?" bytes="F6 32 02 00 2A 6F" response="enum">
        <enum value="00" result="Off"/>
        <enum value="01" result="On"/>
    </command>
    <command name="Freeze On" bytes="F6 32 01 01 2A 6F"/>
    <command name="Freeze Off" bytes="F6 32 01 02 2B 6F"/>
    <command name="Blank?" bytes="F6 35 02 00 2D 6F" response="enum">
        <enum value="00" result="Off"/>
        <enum value="01" result="On"/>
    </command>
    <command name="Blank On" bytes="F6 35 01 00 2C 6F"/>
    <command name="Blank Off" bytes="F6 35 01 01 2D 6F"/>
    <command name="Touch Lock?" bytes="F6 36 02 00 2E 6F" response="enum">
        <enum value="00" result="Off"/>
        <enum value="01" result="On"/>
    </command>
    <command name="Touch Lock On" bytes="F6 36 01 00 2D 6F"/>
    <command name="Touch Lock Off" bytes="F6 36 01 01 2E 6F"/>
