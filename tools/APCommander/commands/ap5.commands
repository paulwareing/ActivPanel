    <command name="Set Color Temp Cold" bytes="F6 34 0A 00 34 6F"/>
    <command name="Set Color Temp Natural" bytes="F6 34 0A 01 35 6F"/>
    <command name="Set Color Temp Warm" bytes="F6 34 0A 02 36 6F"/>
